{
  "name": "firmenabc-scraper-playbook",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "FirmenABC public company data collection playbook with sample-first crawling and delivery checks",
  "scripts": {
    "sample": "node scripts/collect_sample.mjs --targets examples/targets.sample.json --limit 5 --output output/firmenabc.sample.jsonl",
